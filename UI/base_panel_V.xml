<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <object class="GtkGrid" id="main_grid">
    <!-- Titlebar -->
    <child>
      <object class="GtkBox" id="titlebar">
        <property name="spacing">5</property>
        <property name="valign">center</property>
        
        <!-- Temp Box -->
        <child>
          <object class="GtkBox" id="temp_box">
            <property name="spacing">10</property>
          </object>
        </child>
        
        <!-- Title Label -->
        <child>
          <object class="GtkLabel" id="titlelbl">
            <property name="hexpand">true</property>
            <property name="halign">center</property>
            <property name="ellipsize">end</property>
          </object>
        </child>
        
        <!-- Time Box -->
        <child>
          <object class="GtkBox" id="time_box">
            <property name="halign">end</property>
            <child>
              <object class="GtkLabel" id="time">
                <property name="label">00:00 AM</property>
              </object>
            </child>
          </object>
        </child>
        
        <!-- Battery Box -->
        <child>
          <object class="GtkBox" id="battery_box">
            <property name="halign">end</property>
            <property name="no-show-all">true</property>
			<child>
              <object class="GtkLabel" id="battery">
              </object>
            </child>
          </object>
        </child>
      </object>
      <packing>
        <property name="left-attach">0</property>
        <property name="top-attach">0</property>
        <property name="width">1</property>
        <property name="height">1</property>
      </packing>
    </child>
    
    <!-- Action Bar -->
    <child>
      <object class="GtkBox" id="action_bar">
        <property name="orientation">horizontal</property>
        <property name="spacing">5</property>
        <property name="hexpand">true</property>
        <property name="vexpand">false</property>
      </object>
      <packing>
        <property name="left-attach">0</property>
        <property name="top-attach">2</property>
        <property name="width">1</property>
        <property name="height">1</property>
      </packing>
    </child>
  </object>
</interface>